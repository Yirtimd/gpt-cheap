# ==========================================================================
# Supabase
# ==========================================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ==========================================================================
# Inngest — leave empty in dev (inngest-cli handles signing locally)
# ==========================================================================
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ==========================================================================
# LLM providers
# ==========================================================================
OPENAI_API_KEY=     # Leave empty to run OpenAI provider in stub mode
GEMINI_API_KEY=

# ==========================================================================
# Stripe
# ==========================================================================
STRIPE_SECRET_KEY=          # Leave empty for stub mode
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=       # price_xxx from Stripe Dashboard
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=

# ==========================================================================
# Email
# ==========================================================================
RESEND_API_KEY=

# ==========================================================================
# Observability
# ==========================================================================
SENTRY_DSN=                    # Server-side DSN
NEXT_PUBLIC_SENTRY_DSN=        # Client-side DSN (can be same or different)
NEXT_PUBLIC_POSTHOG_KEY=       # Client-side project API key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=               # Server-side project API key (same as public OK)

# ==========================================================================
# Rate limiting (Upstash Redis)
# ==========================================================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ==========================================================================
# Cost guardrails
# ==========================================================================
MAX_GLOBAL_COST_CENTS_PER_DAY=10000
# Set to 1 after Gemini's 500/day grounded-request free tier is exhausted.
GEMINI_GROUNDING_BILLED=0
