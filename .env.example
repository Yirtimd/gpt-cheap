# ==========================================================================
# Supabase
# ==========================================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ==========================================================================
# Inngest — leave empty in dev (inngest-cli handles signing locally)
# ==========================================================================
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ==========================================================================
# LLM providers
# ==========================================================================
OPENAI_API_KEY=     # Leave empty to run OpenAI provider in stub mode
GEMINI_API_KEY=

# ==========================================================================
# Stripe
# ==========================================================================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ==========================================================================
# Email
# ==========================================================================
RESEND_API_KEY=

# ==========================================================================
# Observability
# ==========================================================================
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ==========================================================================
# Cost guardrails
# ==========================================================================
MAX_GLOBAL_COST_CENTS_PER_DAY=10000
# Set to 1 after Gemini's 500/day grounded-request free tier is exhausted.
GEMINI_GROUNDING_BILLED=0
